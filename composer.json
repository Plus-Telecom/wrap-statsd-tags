{
    "name": "plus-telecom/statsd",
    "type": "library",
    "description": "Statsd Laravel 5 wrapper",
    "authors": [
        {
            "name": "Arjay Adong",
            "email": "arjayads@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
